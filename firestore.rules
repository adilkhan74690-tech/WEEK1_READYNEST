rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: Only owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Forms: Public read if published, otherwise owner only. Only owner can write.
    // Allow public updates ONLY if they modify views, responsesCount, or updatedAt.
    match /forms/{formId} {
      allow read: if resource.data.published == true || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if (request.auth != null && request.auth.uid == resource.data.userId) || 
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'responsesCount', 'updatedAt']));
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Responses: Anyone can create (public submission). Only form owner can read/list/delete.
    match /responses/{responseId} {
      allow create: if true;
      allow read, delete: if request.auth != null && 
        (resource.data.formOwnerId == request.auth.uid || 
         get(/databases/$(database)/documents/forms/$(resource.data.formId)).data.userId == request.auth.uid);
    }
  }
}