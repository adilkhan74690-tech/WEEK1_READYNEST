rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles: Only owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Forms: Public read if published, otherwise owner only. Only owner can write.
    match /forms/{formId} {
      allow read: if resource.data.published == true || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Responses: Anyone can create (public submission). Only form owner can read/list.
    match /responses/{responseId} {
      allow create: if true;
      allow read, delete: if request.auth != null && 
        get(/databases/$(database)/documents/forms/$(resource.data.formId)).data.userId == request.auth.uid;
      
      // Allow listing responses for a specific form if the requester owns the form
      allow list: if request.auth != null && 
        request.query.filters.size() > 0 && 
        get(/databases/$(database)/documents/forms/$(request.query.filters[0].value)).data.userId == request.auth.uid;
    }
  }
}